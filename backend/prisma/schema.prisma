generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  status      String   @default("active") // active | archived
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  modules     Module[]
  pages       Page[]
  fields      Field[]
  actions     Action[]
  edges       Edge[]
  commitLogs  CommitLog[]
  summaries   MacroSummary[]

  @@map("projects")
}

model Module {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  name        String
  description String?
  posX        Float    @default(0) @map("pos_x")
  posY        Float    @default(0) @map("pos_y")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  pages   Page[]

  @@map("modules")
}

model Page {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  moduleId  String?  @map("module_id")
  name      String
  posX      Float    @default(0) @map("pos_x")
  posY      Float    @default(0) @map("pos_y")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  module  Module? @relation(fields: [moduleId], references: [id])
  fields  Field[]
  actions Action[]

  @@map("pages")
}

model Field {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  pageId    String?  @map("page_id")
  name      String
  fieldType String   @default("string") @map("field_type")
  posX      Float    @default(0) @map("pos_x")
  posY      Float    @default(0) @map("pos_y")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  page    Page?    @relation(fields: [pageId], references: [id])

  @@map("fields")
}

model Action {
  id         String   @id @default(uuid())
  projectId  String   @map("project_id")
  pageId     String?  @map("page_id")
  name       String
  actionType String   @default("operation") @map("action_type")
  validations Json?   // Array of precondition strings
  posX       Float    @default(0) @map("pos_x")
  posY       Float    @default(0) @map("pos_y")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  page    Page?   @relation(fields: [pageId], references: [id])

  @@map("actions")
}

model Edge {
  id         String   @id @default(uuid())
  projectId  String   @map("project_id")
  sourceId   String   @map("source_id")
  targetId   String   @map("target_id")
  sourceType String   @map("source_type") // module | page | field | action
  targetType String   @map("target_type")
  flowType   String   @default("BUSINESS_FLOW") @map("flow_type") // BUSINESS_FLOW | DATA_FLOW
  status     String   @default("extracted") // extracted | inferred
  label      String?
  sourceQuote String? @map("source_quote")
  createdAt  DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("edges")
}

model CommitLog {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  version     Int      @default(1)
  description String?
  snapshot    Json?    // Full state JSON
  baseVersion Int?     @map("base_version")
  createdAt   DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, version])
  @@map("commit_logs")
}

model MacroSummary {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("macro_summaries")
}
